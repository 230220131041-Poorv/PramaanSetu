# ========================
# FRONTEND CONFIGURATION
# ========================

# Supabase Configuration - DISABLED (using dummy users for demo)
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Backend API Endpoint (Frontend only - DO NOT expose API keys here)
EXPO_PUBLIC_BACKEND_URL=https://your-backend.vercel.app

# LLM Configuration (Frontend only - endpoints, not keys)
EXPO_PUBLIC_LLM_ENDPOINT=https://your-backend.vercel.app/api/llm
EXPO_PUBLIC_VISION_ENDPOINT=https://your-backend.vercel.app/api/vision

# Features & Thresholds
EXPO_PUBLIC_OCR_CONFIDENCE_THRESHOLD=0.75
EXPO_PUBLIC_EMBEDDING_SIMILARITY_THRESHOLD=0.92
EXPO_PUBLIC_MAX_FILE_SIZE=52428800

# Environment
EXPO_PUBLIC_ENVIRONMENT=development

# ========================
# BACKEND CONFIGURATION
# ========================
# NEVER commit this file. Use in .gitignore
# Copy to .env.local or .env.production.local

# API Keys (NEVER expose to frontend)
OPENAI_API_KEY=sk-your-actual-key-here
GEMMINI_API_KEY=your-google-api-key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pramansetu
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# LLM Configuration
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=30000

# Vision Configuration
VISION_MODEL=gemini-2.0-flash
VISION_TIMEOUT=30000
VISION_MAX_FILE_SIZE=52428800

# Secrets Manager (choose one)
SECRETS_MANAGER=aws  # aws | vault | env
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=your-vault-token

# Server Configuration
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# Security
JWT_SECRET=your-jwt-secret-min-32-chars
API_RATE_LIMIT=100
API_RATE_WINDOW_MS=900000

# Monitoring & Analytics
SENTRY_DSN=https://your-sentry-dsn
DATADOG_API_KEY=your-datadog-key
ENABLE_USAGE_TRACKING=true
ENABLE_ERROR_TRACKING=true
ENABLE_COST_TRACKING=true

# Feature Flags
ENABLE_OCR_PREPROCESSING=true
ENABLE_DUPLICATE_DETECTION=true
ENABLE_BATCH_PROCESSING=true
ENABLE_CACHE=true
